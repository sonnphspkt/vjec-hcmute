# API Configuration
# Dev + Vite proxy (khuyến nghị): để /api — hoạt động cả khi mở http://IP-LAN:5173
VITE_API_URL=/api
# Khi build static và API nằm server khác, ví dụ:
# VITE_API_URL=https://api.example.com/api
VITE_SOCKET_URL=http://localhost:5000

# App Configuration
VITE_APP_NAME=UTE Job Platform
VITE_APP_VERSION=1.0.0
